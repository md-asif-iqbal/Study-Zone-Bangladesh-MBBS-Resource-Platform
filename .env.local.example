# ----------------------------------------------------------------------------
# Study Zone - Environment Variables Template
# Copy this file to ".env.local" and fill in real values.
# NEVER commit .env.local (it is gitignored).
# The app runs on mock seed data when these are not set, so you can preview
# the full UI before wiring real backends.
# ----------------------------------------------------------------------------

# MongoDB (Mongoose) - structured data: colleges, subjects, topics, resources,
# MCQs, exam routines, users, todo/progress
MONGODB_URI=

# Firebase (client-side config - safe to expose; real protection = Storage Rules)
# Used for: Email/password auth with email verification + Firebase Storage uploads
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional: protects the DB seed endpoint (POST /api/admin/seed?confirm=true).
# If set, send it as the "x-seed-secret" header when seeding.
SEED_SECRET=
